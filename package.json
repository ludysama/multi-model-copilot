{
  "name": "multi-model-copilot",
  "displayName": "Multi-Model Copilot (DeepSeek V4 + GLM-5.2)",
  "description": "Pick DeepSeek V4 Pro & Flash, plus GLM-5.2 (Zhipu), from the Copilot Chat model picker. Vision, thinking mode, agent tools — zero config, BYOK.",
  "icon": "resources/icon.png",
  "version": "0.6.2",
  "publisher": "ludysama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ludysama/multi-model-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "deepseek",
    "deepseek v4",
    "deepseek-v4",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "deepseek",
        "displayName": "DeepSeek"
      }
    ],
    "commands": [
      {
        "command": "multi-model-copilot.setApiKey",
        "title": "%multi-model-copilot.command.setApiKey%"
      },
      {
        "command": "multi-model-copilot.getApiKey",
        "title": "%multi-model-copilot.command.getApiKey%"
      },
      {
        "command": "multi-model-copilot.clearApiKey",
        "title": "%multi-model-copilot.command.clearApiKey%"
      },
      {
        "command": "multi-model-copilot.setVisionModel",
        "title": "%multi-model-copilot.command.setVisionModel%"
      },
      {
        "command": "multi-model-copilot.openSettings",
        "title": "%multi-model-copilot.command.openSettings%"
      },
      {
        "command": "multi-model-copilot.showLogs",
        "title": "%multi-model-copilot.command.showLogs%"
      },
      {
        "command": "multi-model-copilot.openRequestDumpsFolder",
        "title": "%multi-model-copilot.command.openRequestDumpsFolder%"
      }
    ],
    "walkthroughs": [
      {
        "id": "deepseekGettingStarted",
        "title": "%multi-model-copilot.walkthrough.title%",
        "description": "%multi-model-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "forkOrigin",
            "title": "%multi-model-copilot.walkthrough.forkOrigin.title%",
            "description": "%multi-model-copilot.walkthrough.forkOrigin.description%"
          },
          {
            "id": "setApiKey",
            "title": "%multi-model-copilot.walkthrough.setApiKey.title%",
            "description": "%multi-model-copilot.walkthrough.setApiKey.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:multi-model-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%multi-model-copilot.walkthrough.showModels.title%",
            "description": "%multi-model-copilot.walkthrough.showModels.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%multi-model-copilot.walkthrough.advancedSettings.title%",
            "description": "%multi-model-copilot.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%multi-model-copilot.config.title%",
      "properties": {
        "multi-model-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "%multi-model-copilot.config.baseUrl.description%"
        },
        "multi-model-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%multi-model-copilot.config.maxTokens.description%"
        },
        "multi-model-copilot.experimental.stabilizeToolList": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%multi-model-copilot.config.experimental.stabilizeToolList.description%",
          "tags": [
            "experimental"
          ]
        },
        "multi-model-copilot.modelIdOverrides": {
          "type": "object",
          "default": {
            "deepseek-v4-flash": "deepseek-v4-flash",
            "deepseek-v4-pro": "deepseek-v4-pro",
            "glm-5.2": "glm-5.2",
            "glm-5.2-coding": "glm-5.2"
          },
          "description": "%multi-model-copilot.config.modelIdOverrides.description%",
          "additionalProperties": false,
          "properties": {
            "deepseek-v4-flash": {
              "type": "string",
              "description": "%multi-model-copilot.config.modelIdOverrides.deepseek-v4-flash.description%"
            },
            "deepseek-v4-pro": {
              "type": "string",
              "description": "%multi-model-copilot.config.modelIdOverrides.deepseek-v4-pro.description%"
            },
            "glm-5.2": {
              "type": "string",
              "description": "%multi-model-copilot.config.modelIdOverrides.glm-5.2.description%"
            },
            "glm-5.2-coding": {
              "type": "string",
              "description": "%multi-model-copilot.config.modelIdOverrides.glm-5.2-coding.description%"
            }
          }
        },
        "multi-model-copilot.visionModel": {
          "type": "string",
          "default": "",
          "tags": [
            "advanced"
          ],
          "markdownDescription": "%multi-model-copilot.config.visionModel.description%"
        },
        "multi-model-copilot.visionPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Describe all image attachments in this message.\n\nIf there is one image, describe it directly.\nIf there are multiple images:\n1. Describe each image separately, preserving their order.\n2. Then provide a combined description explaining the overall context and relationships across the images.\n\nReturn one concise factual description suitable for inserting into a text-only chat prompt. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
          "markdownDescription": "%multi-model-copilot.config.visionPrompt.description%"
        },
        "multi-model-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%multi-model-copilot.config.debugMode.minimal.label%",
            "%multi-model-copilot.config.debugMode.metadata.label%",
            "%multi-model-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%multi-model-copilot.config.debugMode.minimal.description%",
            "%multi-model-copilot.config.debugMode.metadata.description%",
            "%multi-model-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%multi-model-copilot.config.debugMode.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "vscode:prepublish": "bash .github/scripts/prepare-marketplace-readme.sh && npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "oxlint",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "package": "vsce package --readme-path dist/README.marketplace.md -o dist/",
    "login": "vsce login ludysama"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "0.10.12",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}